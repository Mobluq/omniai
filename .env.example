# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omniai?schema=public"

# Auth.js / NextAuth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# AI providers. Configure in production secrets, never in client-exposed variables.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
MISTRAL_API_KEY=""
STABILITY_API_KEY=""

# Billing and observability
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
SENTRY_DSN=""

# App
APP_URL="http://localhost:3000"

# Optional one-time admin/bootstrap user for seeded environments.
# Set these only in secure local or deployment environment variables.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="OmniAI Admin"
ADMIN_WORKSPACE_NAME="OmniAI Admin Workspace"
