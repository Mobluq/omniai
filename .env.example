# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omniai?schema=public"

# Auth.js / NextAuth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# AI providers. Configure in production secrets, never in client-exposed variables.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
MISTRAL_API_KEY=""
STABILITY_API_KEY=""

# Optional provider model overrides.
OPENAI_TEXT_MODEL="gpt-5-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
ANTHROPIC_MODEL="claude-sonnet-4-5"
GOOGLE_AI_MODEL="gemini-2.5-flash"
MISTRAL_MODEL="mistral-large-latest"

# Amazon Bedrock / AWS. Prefer deployment secrets or an AWS runtime role.
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
AWS_BEDROCK_MODEL_ID=""

# Billing and observability
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
SENTRY_DSN=""

# App
APP_URL="http://localhost:3000"
APP_ENCRYPTION_KEY=""

# Optional one-time admin/bootstrap user for seeded environments.
# Set these only in secure local or deployment environment variables.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="OmniAI Admin"
ADMIN_WORKSPACE_NAME="OmniAI Admin Workspace"

# Signup policy. Production defaults to invite-only if SIGNUP_MODE is unset.
SIGNUP_MODE="public"
SIGNUP_INVITE_CODE=""
