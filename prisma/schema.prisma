generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  owner
  admin
  member
  viewer
}

enum WorkspaceType {
  personal
  team
  enterprise
}

enum MessageRole {
  user
  assistant
  system
  tool
}

enum RoutingMode {
  manual
  suggest
  auto
}

enum ProviderStatus {
  available
  disabled
  degraded
  beta
}

enum ModelCapability {
  text_generation
  code_generation
  image_generation
  image_editing
  image_analysis
  long_context
  research
  summarization
  data_analysis
  document_analysis
  creative_writing
  business_writing
  reasoning
  function_calling
  embeddings
}

enum CostTier {
  low
  medium
  high
  premium
}

enum RequestType {
  text_generation
  image_generation
  embedding
  routing
  recommendation
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
}

enum KnowledgeSourceType {
  file
  url
  note
}

enum BillingInterval {
  month
  year
}

enum ProjectStatus {
  active
  archived
}

enum ArtifactType {
  document
  image
  code
  research
  proposal
  prompt
  other
}

enum NotificationType {
  system
  security
  usage
  provider
  billing
  routing
  workspace
}

model User {
  id                  String                @id @default(cuid())
  name                String?
  email               String?               @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  jobTitle            String?
  companyName         String?
  timezone            String                @default("UTC")
  locale              String                @default("en")
  defaultRoutingMode  RoutingMode           @default(suggest)
  defaultModelId      String?
  dataRetentionDays   Int                   @default(365)
  memoryEnabled       Boolean               @default(true)
  twoFactorEnabled    Boolean               @default(false)
  twoFactorSecretEncrypted String?           @db.Text
  twoFactorConfirmedAt DateTime?
  twoFactorRecoveryCodesEncrypted String?    @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  accounts            Account[]
  sessions            Session[]
  notificationPreference NotificationPreference?
  notifications       Notification[]
  memberships         WorkspaceMember[]
  workspaceInvitesCreated WorkspaceInvite[] @relation("WorkspaceInvitesCreated")
  workspaceInvitesAccepted WorkspaceInvite[] @relation("WorkspaceInvitesAccepted")
  conversations       Conversation[]
  messages            Message[]
  providerConfigs     AIProviderConfig[]
  recommendationLogs  RecommendationLog[]
  usageLogs           UsageLog[]
  auditLogs           AuditLog[]
  conversationMemory  ConversationMemory[]
  projects            Project[]
  artifacts           Artifact[]

  @@index([email])
}

model NotificationPreference {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  emailProductUpdates    Boolean  @default(false)
  emailUsageAlerts       Boolean  @default(true)
  emailSecurityAlerts    Boolean  @default(true)
  emailWeeklyDigest      Boolean  @default(true)
  providerIncidentAlerts Boolean  @default(true)
  billingAlerts          Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  type               WorkspaceType       @default(personal)
  defaultRoutingMode RoutingMode         @default(suggest)
  defaultModelId     String?
  memoryEnabled      Boolean             @default(true)
  retentionDays      Int                 @default(365)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  members            WorkspaceMember[]
  invites            WorkspaceInvite[]
  conversations      Conversation[]
  providerConfigs    AIProviderConfig[]
  recommendationLogs RecommendationLog[]
  usageLogs          UsageLog[]
  knowledgeSources   KnowledgeSource[]
  subscriptions      Subscription[]
  auditLogs          AuditLog[]
  conversationMemory ConversationMemory[]
  projects           Project[]
  artifacts          Artifact[]
  notifications      Notification[]

  @@index([slug])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  workspaceId String?
  type        NotificationType @default(system)
  title       String
  body        String           @db.Text
  actionUrl   String?
  readAt      DateTime?
  archivedAt  DateTime?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([workspaceId, createdAt])
  @@index([type, createdAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model WorkspaceInvite {
  id           String        @id @default(cuid())
  workspaceId  String
  email        String
  role         WorkspaceRole @default(member)
  tokenHash    String        @unique
  invitedById  String?
  acceptedById String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy    User?         @relation("WorkspaceInvitesCreated", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy   User?         @relation("WorkspaceInvitesAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, email])
  @@index([expiresAt])
  @@index([acceptedAt, revokedAt])
}

model Conversation {
  id             String      @id @default(cuid())
  workspaceId    String
  projectId      String?
  createdById    String
  title          String
  activeProvider String?
  activeModelId  String?
  routingMode    RoutingMode @default(suggest)
  archivedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy      User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  messages       Message[]
  memories       ConversationMemory[]
  artifacts      Artifact[]

  @@index([workspaceId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([createdById])
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  workspaceId      String
  userId           String?
  role             MessageRole
  content          String       @db.Text
  provider         String?
  modelId          String?
  modelDisplayName String?
  tokenInput       Int?
  tokenOutput      Int?
  costEstimate     Decimal?     @db.Decimal(12, 6)
  metadata         Json?
  createdAt        DateTime     @default(now())
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([workspaceId, createdAt])
}

model AIProviderConfig {
  id                  String         @id @default(cuid())
  workspaceId          String?
  userId               String?
  provider             String
  displayName          String
  encryptedApiKey      String?        @db.Text
  isEnabled            Boolean        @default(false)
  allowedCapabilities  ModelCapability[]
  status               ProviderStatus @default(disabled)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  workspace            Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                 User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([workspaceId, provider])
  @@index([userId, provider])
}

model ModelRegistry {
  id                    String            @id @default(cuid())
  provider              String
  modelId               String
  displayName           String
  description           String
  capabilities          ModelCapability[]
  costTier              CostTier
  speedRating           Int
  reasoningStrength     Int
  writingStrength       Int
  codingStrength        Int
  imageGeneration       Boolean           @default(false)
  contextWindowEstimate Int
  status                ProviderStatus    @default(available)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([provider, modelId])
  @@index([status, provider])
}

model RecommendationLog {
  id                  String      @id @default(cuid())
  userId              String
  workspaceId         String
  promptHash          String
  detectedIntent      String
  currentProvider     String?
  currentModelId      String?
  recommendedProvider String
  recommendedModelId  String
  confidence          Decimal     @db.Decimal(4, 3)
  reason              String
  accepted            Boolean?
  routingMode         RoutingMode
  createdAt           DateTime    @default(now())
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace           Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
}

model UsageLog {
  id                 String      @id @default(cuid())
  userId             String
  workspaceId        String
  conversationId     String?
  provider           String
  modelId            String
  requestType        RequestType
  tokenInputEstimate Int         @default(0)
  tokenOutputEstimate Int        @default(0)
  costEstimate       Decimal     @default(0) @db.Decimal(12, 6)
  success            Boolean
  errorCode          String?
  createdAt          DateTime    @default(now())
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace          Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([provider, modelId])
}

model KnowledgeSource {
  id          String              @id @default(cuid())
  workspaceId String
  projectId   String?
  type        KnowledgeSourceType
  title       String
  sourceUri   String?
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  documents   Document[]

  @@index([workspaceId, type])
  @@index([projectId, createdAt])
}

model Project {
  id                 String          @id @default(cuid())
  workspaceId        String
  createdById        String
  name               String
  slug               String
  description        String?         @db.Text
  instructions       String?         @db.Text
  defaultRoutingMode RoutingMode     @default(suggest)
  defaultProvider    String?
  defaultModelId     String?
  status             ProjectStatus   @default(active)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy          User            @relation(fields: [createdById], references: [id], onDelete: Restrict)
  conversations      Conversation[]
  knowledgeSources   KnowledgeSource[]
  artifacts          Artifact[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status, updatedAt])
  @@index([createdById])
}

model Artifact {
  id             String       @id @default(cuid())
  workspaceId    String
  projectId      String?
  conversationId String?
  messageId      String?
  createdById    String?
  type           ArtifactType @default(other)
  title          String
  content        String       @db.Text
  provider       String?
  modelId        String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdBy      User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([conversationId])
  @@index([messageId])
}

model Document {
  id                String          @id @default(cuid())
  workspaceId       String
  knowledgeSourceId String
  title             String
  contentHash       String?
  sanitizedText     String?         @db.Text
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  knowledgeSource   KnowledgeSource @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)
  chunks            DocumentChunk[]

  @@index([workspaceId, createdAt])
  @@index([knowledgeSourceId])
}

model DocumentChunk {
  id          String            @id @default(cuid())
  workspaceId String
  documentId  String
  chunkIndex  Int
  content     String            @db.Text
  tokenCount  Int               @default(0)
  metadata    Json?
  createdAt   DateTime          @default(now())
  document    Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embeddings  EmbeddingRecord[]

  @@unique([documentId, chunkIndex])
  @@index([workspaceId, documentId])
}

model EmbeddingRecord {
  id              String         @id @default(cuid())
  workspaceId     String
  documentChunkId String
  provider        String
  modelId         String
  embedding       Unsupported("vector")?
  dimensions      Int
  createdAt       DateTime       @default(now())
  documentChunk   DocumentChunk  @relation(fields: [documentChunkId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider, modelId])
  @@index([documentChunkId])
}

model ConversationMemory {
  id             String       @id @default(cuid())
  workspaceId    String
  conversationId String
  userId         String?
  summary        String       @db.Text
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, conversationId])
}

model Plan {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  description    String
  priceCents     Int             @default(0)
  currency       String          @default("usd")
  interval       BillingInterval @default(month)
  includedCredits Int            @default(0)
  maxSeats       Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  subscriptions  Subscription[]
  usageLimits    UsageLimit[]
}

model Subscription {
  id                   String             @id @default(cuid())
  workspaceId           String
  planId                String
  status                SubscriptionStatus @default(incomplete)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  workspace             Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan                  Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  billingEvents         BillingEvent[]

  @@index([workspaceId, status])
  @@index([stripeCustomerId])
}

model UsageLimit {
  id          String   @id @default(cuid())
  planId      String
  metric      String
  limit       Int
  period      String   @default("month")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, metric, period])
}

model BillingEvent {
  id             String       @id @default(cuid())
  subscriptionId String?
  stripeEventId  String?      @unique
  eventType      String
  payload        Json?
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  workspaceId String?
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

model RateLimitBucket {
  id           String    @id @default(cuid())
  keyHash      String    @unique
  scope        String
  count        Int       @default(0)
  resetAt      DateTime
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([scope, resetAt])
  @@index([blockedUntil])
}
