{
  "name": "bd-select",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "ts-node --project tsconfig.test.json -r tsconfig-paths/register tests/run-tests.ts",
    "validate": "npm run db:validate && npm run typecheck && npm run lint && npm test",
    "ci": "npm run validate && npm run build",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register prisma/seed.ts",
    "postinstall": "prisma generate",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/client": "6.19.3",
    "@radix-ui/react-slot": "1.2.4",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "next": "16.2.5",
    "next-auth": "4.24.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "0.0.1",
    "tailwind-merge": "3.5.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
