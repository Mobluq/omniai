# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bd_select?schema=public"

# Auth/session foundation
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
APP_ENCRYPTION_KEY=""
AUDIT_SIGNING_SECRET=""

# Signup policy. Production should default to invite-only.
SIGNUP_MODE="public"
SIGNUP_INVITE_CODE=""
REQUIRE_EMAIL_VERIFICATION="false"
ALLOW_TRUSTED_AUTH_HEADERS="false"

# Optional first owner account for seeded environments.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="BD Select Admin"

# Marketplace integrations. Leave blank until the corresponding feature is built.
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_WEBHOOK_SECRET=""
TERMII_API_KEY=""
SENDGRID_API_KEY=""
MONO_SECRET_KEY=""
DOJAH_APP_ID=""
DOJAH_PRIVATE_KEY=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_IMAGES_ACCOUNT_ID=""

# Observability
SENTRY_DSN=""
